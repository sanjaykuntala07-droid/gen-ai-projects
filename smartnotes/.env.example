# ============================================
# SmartNotes Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://smartnotes:smartnotes_dev@localhost:5432/smartnotes

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth0 (stubbed in development — set these for production)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.smartnotes.dev

# SendGrid (optional — reminders log to console without this)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=reminders@smartnotes.dev

# Sentry (optional)
SENTRY_DSN=
